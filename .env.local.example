# =============================================
# FIREBASE CLIENT (Public - safe for frontend)
# =============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# =============================================
# FIREBASE ADMIN (Server-side only - SECRET)
# =============================================
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
# Paste the private key with literal \n for newlines
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# =============================================
# GOOGLE SHEETS (Server-side only - SECRET)
# =============================================
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your_project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# The ID of the master Google Spreadsheet (from the URL)
# You can also set this from Admin > Settings inside the app
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
